---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <style>
      body {
        font-family: system-ui;
        margin: 2rem;
      }
      h1 {
        color: #333;
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
